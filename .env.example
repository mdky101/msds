# 이 파일은 "어떤 값이 필요한지" 알려주는 양식입니다. 실제 키는 여기 쓰지 마세요.
# 실제 키는 .env.local 에 넣어야 Next.js가 읽습니다.

# Google AI Studio에서 발급: https://aistudio.google.com/apikey
# 1단계에서는 라벨 판독(비전)에만 쓰이고, 2단계에서 웹검색(그라운딩)에도 같은 키를 쓴다.
GEMINI_API_KEY=

# 판독 모델. 비워두면 gemini-3.5-flash.
# 모델이 은퇴하면 404가 나므로 그때 여기서만 바꾸면 된다 (코드 수정 불필요).
# 쓸 수 있는 모델 확인:
#   curl "https://generativelanguage.googleapis.com/v1beta/models?key=$GEMINI_API_KEY"
# 주의: 목록에 떠도 신규 사용자에게는 404일 수 있다. 실제 generateContent로 확인할 것.
GEMINI_MODEL=

# 공공데이터포털 "물질안전보건자료 조회 서비스" 일반 인증키 (2단계에서 사용)
# https://www.data.go.kr/data/15157612/openapi.do
KOSHA_SERVICE_KEY=

# 네이버 검색 API (상표명 제품의 제조사 MSDS를 웹에서 찾을 때 사용)
# https://developers.naver.com/apps/#/register → 검색 API 선택
# 무료 25,000회/일, 카드 불필요.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
